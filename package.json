{
  "name": "mojamanga-website",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --check .",
    "check": "prettier --write . && eslint --fix",
    "post-cta-init": "pnpm dlx create-db@latest --user-agent tanstack/tsrouter",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:seed": "dotenv -e .env.local -- prisma db seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1021.0",
    "@aws-sdk/s3-request-presigner": "^3.1021.0",
    "@base-ui/react": "^1.2.0",
    "@better-auth/i18n": "^1.5.5",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/cron": "^1.4.1",
    "@elysiajs/eden": "^1.4.8",
    "@elysiajs/node": "^1.4.5",
    "@elysiajs/openapi": "^1.4.14",
    "@floating-ui/react": "^0.27.19",
    "@marsidev/react-turnstile": "^1.4.2",
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@sinclair/typebox": "^0.34.48",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-form-start": "^1.28.4",
    "@tanstack/react-query": "^5.66.5",
    "@tanstack/react-query-devtools": "^5.84.2",
    "@tanstack/react-router": "1.158.0",
    "@tanstack/react-router-devtools": "1.158.0",
    "@tanstack/react-router-ssr-query": "1.158.0",
    "@tanstack/react-start": "1.158.0",
    "@tanstack/router-plugin": "1.158.0",
    "@unpic/react": "^1.0.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "better-auth": "^1.5.5",
    "clsx": "^2.1.1",
    "elysia": "^1.4.28",
    "immer": "^11.1.4",
    "lucide-react": "^1.7.0",
    "motion": "^12.34.3",
    "nitro": "npm:nitro-nightly@latest",
    "openapi-types": "^12.1.3",
    "prisma": "^7.2.0",
    "react": "^19.2.0",
    "react-cropper": "^2.3.3",
    "react-dom": "^19.2.0",
    "react-dropzone": "^15.0.0",
    "react-image-file-resizer": "^0.4.8",
    "safe-mdx": "^1.3.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@content-collections/core": "^0.14.3",
    "@content-collections/vite": "^0.2.9",
    "@tanstack/devtools-vite": "^0.3.11",
    "@tanstack/eslint-config": "^0.3.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "autoprefixer": "^10.4.24",
    "dotenv-cli": "^10.0.0",
    "jsdom": "^27.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.5.3",
    "remark": "^15.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx": "^3.1.1",
    "sass": "^1.97.3",
    "tsx": "^4.20.6",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  }
}
