generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ================= USER & AUTH =================

model User {
  id              String     @id @default(cuid(2))
  name            String
  email           String
  emailVerified   Boolean    @default(false)
  image           String?
  backgroundCover String?
  role            UserRole   @default(USER)
  username        String     @unique
  displayUsername String
  status          UserStatus @default(NORMAL)

  sessions Session[]
  accounts Account[]

  createdTeams            Team[]                   @relation("TeamCreator")
  teamMemberships         TeamMember[]
  uploadedChapters        Chapter[]
  comments                Comment[]
  likes                   Like[]
  dislikes                Dislike[]
  ratings                 Rating[]
  bookmarksFolders        BookmarkFolder[]
  bookmarks               Bookmark[]
  publishingSubscriptions PublishingSubscription[]
  news                    News[]
  notifications           Notification[]
  workProposals           WorkProposal[]
  workEditions            WorkVersion[]
  complaints              Complaint[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid(2))
  expiresAt DateTime
  token     String
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([token])
  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid(2))
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid(2))
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

// ================= TEAMS =================

model Team {
  id            String     @id @default(cuid(2))
  name          String
  coverUrl      String?
  backgroundUrl String?
  description   String?
  status        TeamStatus @default(PENDING)

  rejectionReason String?

  creatorId String
  creator   User   @relation("TeamCreator", fields: [creatorId], references: [id])

  members            TeamMember[]
  links              TeamLink[]
  publishingVersions PublishingVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teams")
}

model TeamLink {
  id   String   @id @default(cuid(2))
  type LinkType
  url  String

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("team_links")
}

model TeamMember {
  id                String     @id @default(cuid(2))
  userId            String
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId            String
  team              Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  roles             TeamRole[] @default([TRANSLATOR])
  canPublish        Boolean    @default(false)
  canEditTeamInfo   Boolean    @default(false)
  canDeleteChapters Boolean    @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, teamId]) // Юзер не може бути двічі в одній команді
  @@map("team_members")
}

// ================= CONTENT: WORKS =================

model Work {
  id             String             @id @default(cuid(2))
  type           WorkType
  approvalStatus WorkApprovalStatus @default(PENDING)

  currentVersionId String?       @unique
  currentVersion   WorkVersion?  @relation("CurrentVersion", fields: [currentVersionId], references: [id])
  versions         WorkVersion[] @relation("WorkHistory")

  publishers PublishingVersion[]
  comments   Comment[]
  ratings    Rating[]
  proposals  WorkProposal[]
  bookmarks  Bookmark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("works")
}

model WorkVersion {
  id     String @id @default(cuid(2))
  workId String
  work   Work   @relation("WorkHistory", fields: [workId], references: [id], onDelete: Cascade)

  editorId String
  editor   User   @relation(fields: [editorId], references: [id])

  // Версіоновані поля
  ukrName           String
  enName            String?
  ogName            String
  description       String?
  coverImage        String
  backgroundImage   String?
  releaseYear       Int
  ageRestriction    Int
  isNSFW            Boolean           @default(false)
  workStatus        WorkStatus
  translationStatus TranslationStatus

  tags   Tag[]
  genres Genre[]
  people WorkVersionToPerson[]

  changeReason String?

  proposalId String?       @unique
  proposal   WorkProposal? @relation(fields: [proposalId], references: [id])

  createdAt DateTime @default(now())

  // Зворотний зв'язок
  workAsCurrent Work? @relation("CurrentVersion")

  @@map("work_versions")
}

model WorkVersionToPerson {
  versionId String
  personId  String
  role      PersonRole

  version WorkVersion @relation(fields: [versionId], references: [id])
  person  Person      @relation(fields: [personId], references: [id])

  @@id([versionId, personId, role])
}

model WorkProposal {
  id String @id @default(cuid(2))

  userId String
  user   User   @relation(fields: [userId], references: [id])

  workId String
  work   Work   @relation(fields: [workId], references: [id])

  status ProposalStatus @default(PENDING)

  // --- Поля для зміни (Nullable) ---
  // Якщо поле null - значить його змінювати не пропонують
  suggestedUkrName         String?
  suggestedEnName          String?
  suggestedOgName          String?
  suggestedDescription     String?  @db.Text
  suggestedCoverImage      String?
  suggestedBackgroundImage String?
  suggestedReleaseYear     Int?
  suggestedAgeRestriction  Int?
  suggestedIsNSFW          Boolean?
  suggestedTagsJson        Json?
  suggestedGenresJson      Json?
  suggestedAuthorsJson     Json?
  suggestedArtistsJson     Json?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workVersion WorkVersion?

  @@map("work_proposals")
}

// ================= METADATA (TAGS, AUTHORS...) =================

model Tag {
  id   String @id @default(cuid(2))
  name String @unique

  workVersions WorkVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tags")
}

model Genre {
  id   String @id @default(cuid(2))
  name String @unique

  workVersions WorkVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("genres")
}

model Person {
  id    String                @id @default(cuid(2))
  name  String                @unique
  works WorkVersionToPerson[]
}

// ================= PUBLISHING & CHAPTERS =================

model PublishingVersion {
  id     String @id @default(cuid(2))
  teamId String
  team   Team   @relation(fields: [teamId], references: [id])
  workId String
  work   Work   @relation(fields: [workId], references: [id])

  chapters                Chapter[]
  publishingSubscriptions PublishingSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, workId]) // Одна команда - одна версія перекладу для твору
  @@map("publishing_versions")
}

model Chapter {
  id              String             @id @default(cuid(2))
  name            String?
  volumeNum       Float
  chapterNum      Float
  approvalStatus  WorkApprovalStatus @default(PENDING)
  rejectionReason String?

  publishingVersionId String
  publishingVersion   PublishingVersion @relation(fields: [publishingVersionId], references: [id])

  uploaderId String
  uploader   User   @relation(fields: [uploaderId], references: [id])

  pages     Page[]
  bookmarks Bookmark[]
  likes     Like[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([publishingVersionId, volumeNum, chapterNum]) // Унікальність в межах версії команди
  @@map("chapters")
}

model Page {
  id        String  @id @default(cuid(2))
  chapterId String
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  pageNum   Int
  imageUrl  String

  comments Comment[]

  @@map("pages")
}

// ================= SOCIAL & INTERACTION =================

model Comment {
  id           String  @id @default(cuid(2))
  content      String
  isDeleted    Boolean @default(false)
  isHidden     Boolean @default(false)
  hidingReason String?

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  pageId String?
  page   Page?   @relation(fields: [pageId], references: [id], onDelete: Cascade)

  workId String?
  work   Work?   @relation(fields: [workId], references: [id], onDelete: Cascade)

  // Closure Table Relations
  ancestors   CommentClosure[] @relation("Ancestors")
  descendants CommentClosure[] @relation("Descendants")

  likes      Like[]
  dislikes   Dislike[]
  complaints Complaint[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comments")
}

model CommentClosure {
  ancestorId   String
  descendantId String
  depth        Int

  ancestor   Comment @relation("Ancestors", fields: [ancestorId], references: [id], onDelete: Cascade)
  descendant Comment @relation("Descendants", fields: [descendantId], references: [id], onDelete: Cascade)

  @@id([ancestorId, descendantId])
  // Індекси (опціонально, але бажано для Closure Table, якщо будуть складні вибірки)
  @@index([descendantId])
  @@index([ancestorId])
  @@map("comment_closures")
}

// Розділені лайки для чистоти схеми
model Like {
  id     String @id @default(cuid(2))
  userId String
  user   User   @relation(fields: [userId], references: [id])

  commentId String?
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  chapterId String?
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, commentId]) // Юзер може лайкнути комент лише раз
  @@map("likes")
}

model Dislike {
  id     String @id @default(cuid(2))
  userId String
  user   User   @relation(fields: [userId], references: [id])

  commentId String?
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  @@map("dislikes")
}

model Rating {
  id     String @id @default(cuid(2))
  score  Int // 1-10 або 1-5
  userId String
  user   User   @relation(fields: [userId], references: [id])
  workId String
  work   Work   @relation(fields: [workId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, workId])
  @@map("ratings")
}

model BookmarkFolder {
  id         String            @id @default(cuid(2))
  name       String
  isSystem   Boolean           @default(false)
  systemType SystemFolderType?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookmarks Bookmark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@map("bookmark_folders")
}

model Bookmark {
  id String @id @default(cuid(2))

  folderId String
  folder   BookmarkFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  workId String
  work   Work   @relation(fields: [workId], references: [id], onDelete: Cascade)

  // Прогрес читання (остання глава)
  lastChapterId String?
  lastChapter   Chapter? @relation(fields: [lastChapterId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([folderId, workId])
  @@map("bookmarks")
}

// ================= SUBSCRIPTIONS (NOTIFICATIONS) =================

model PublishingSubscription {
  id String @id @default(cuid(2))

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Підписка йде на конкретний переклад конкретної команди
  publishingVersionId String
  publishingVersion   PublishingVersion @relation(fields: [publishingVersionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // Захист від дублікатів підписок
  @@unique([userId, publishingVersionId])
  @@map("publishing_subscriptions")
}

model Notification {
  id          String           @id @default(cuid(2))
  type        NotificationType
  data        Json // { workId: "...", title: "..." }
  isRead      Boolean          @default(false)
  isImportant Boolean          @default(false)
  /**
   * Якщо сповіщення важливе, воно не видалятиметься автоматично через деякий час.
   * Користувач може зберігати такі сповіщення
   */

  receiverId String
  receiver   User   @relation(fields: [receiverId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notifications")
}

// ================= MISC =================

model News {
  id        String   @id @default(cuid(2))
  title     String
  content   String   @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@map("news")
}

model Complaint {
  id String @id @default(cuid(2))

  reporterId String
  reporter   User   @relation(fields: [reporterId], references: [id])

  commentId String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  reason  ReportReason
  details String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Захист від спаму: один юзер може поскаржитися на один коментар лише раз
  @@unique([reporterId, commentId])
  @@map("complaints")
}

// ================= ENUMS =================

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum UserStatus {
  NORMAL
  RESTRICTED
  BANNED
}

enum TeamStatus {
  PENDING
  APPROVED
  REJECTED
  BANNED
}

enum LinkType {
  DISCORD
  INSTAGRAM
  TELEGRAM
  TIKTOK
  FACEBOOK
  X
  MONOBANK
  BUYMEACOFFEE
  DONATELLO
  SITE
}

enum TeamRole {
  ADMIN
  TRANSLATOR
  CLEANER
  TYPER
}

enum PersonRole {
  AUTHOR
  ARTIST
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum WorkType {
  MANGA
  MANHWA
  MANHUA
  MALOPUS
  COMIC
  WEBCOMIC
}

enum WorkStatus {
  ONGOING
  ENDED
  ANNOUNCEMENT
  PAUSED
  DISCONTINUED
}

enum TranslationStatus {
  ONGOING
  ENDED
  FREEZED
  DROPPED
}

enum NotificationType {
  NEW_CHAPTER
  COMMENT_REPLY
  WORK_APPROVED
  WORK_REJECTED
  PROPOSAL_ACCEPTED
  PROPOSAL_REJECTED
  USER_BANNED
}

enum ReportReason {
  USER_OFFENCE // Образи
  SPOILERS // Спойлери
  AD // Реклама
  SLURS // Нецензурна лексика / Мова ворожнечі
  PROHIBITED_CONTENT // Заборонений контент 18+ і т.д.
  CONFLICTS // Провокація конфліктів
  OFFTOPIC // Не по темі
  OTHER
}

enum WorkApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SystemFolderType {
  READING
  COMPLETED
  ON_HOLD
  DROPPED
  PLAN_TO_READ
}
